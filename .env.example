# Database (Supabase PostgreSQL direct connection)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Supabase auth
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis (rate limiting)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Base URL (for verification email links etc.)
BASE_URL=http://localhost:8000

# LLM
GROQ_API_KEY=

# Email sending (platform SendGrid API key — emails are sent from the user's verified email)
SENDGRID_API_KEY=

# Company discovery
SERPAPI_API_KEY=

# Email discovery
HUNTER_API_KEY=
